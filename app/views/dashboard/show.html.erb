<div class="p-6 sm:p-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Dashboard</h1>

  <%# Meetings Agenda %>
  <section class="mb-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Meetings</h2>
      <%= link_to "View all", meetings_path, class: "text-sm text-blue-600 hover:text-blue-700 font-medium" %>
    </div>
    <% if @recent_meetings.any? %>
      <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
        <% @recent_meetings.group_by { |m| m.date.strftime("%B %Y") }.each_with_index do |(month, meetings), idx| %>
          <div class="<%= 'border-t border-gray-200' unless idx == 0 %>">
            <div class="px-4 py-2 bg-gray-50 border-b border-gray-100">
              <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= month %></h3>
            </div>
            <% meetings.each_with_index do |meeting, midx| %>
              <%= link_to meeting_path(meeting), class: "flex items-center gap-4 px-4 py-3 hover:bg-blue-50 transition #{'border-t border-gray-100' unless midx == 0}" do %>
                <div class="flex-shrink-0 w-12 text-center">
                  <div class="text-2xl font-bold text-gray-900 leading-none"><%= meeting.date.day %></div>
                  <div class="text-xs text-gray-400 uppercase mt-0.5"><%= meeting.date.strftime("%a") %></div>
                </div>
                <div class="flex-shrink-0 w-px h-10 bg-gray-200"></div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2">
                    <span class="font-medium text-gray-900"><%= meeting.meeting_type.titleize %> Meeting</span>
                    <% if meeting.date >= Date.current %>
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">Upcoming</span>
                    <% end %>
                  </div>
                  <div class="text-sm text-gray-500 mt-0.5">
                    <%= meeting.agenda_sections.size %> sections · <%= meeting.agenda_items.size %> items
                  </div>
                </div>
                <div class="flex-shrink-0 text-gray-300">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/></svg>
                </div>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-lg border border-gray-200 p-8 text-center">
        <p class="text-gray-500">No meetings available yet.</p>
      </div>
    <% end %>
  </section>

  <%# Council Members %>
  <section class="mb-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Council Members</h2>
      <%= link_to "View all", council_members_path, class: "text-sm text-blue-600 hover:text-blue-700 font-medium" %>
    </div>
    <% if @current_members.any? %>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @current_members.each do |member| %>
          <%= link_to council_member_path(member), class: "block bg-white rounded-lg border border-gray-200 p-5 hover:border-blue-300 hover:shadow-sm transition" do %>
            <h3 class="font-semibold text-gray-900"><%= member.full_name %></h3>
            <span class="inline-flex items-center mt-1.5 px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
              <%= member.seat_label %>
            </span>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-lg border border-gray-200 p-8 text-center">
        <p class="text-gray-500">No council members available yet.</p>
      </div>
    <% end %>
  </section>

  <%# Topics %>
  <section>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Popular Topics</h2>
      <%= link_to "View all", tags_path, class: "text-sm text-blue-600 hover:text-blue-700 font-medium" %>
    </div>
    <% if @top_tags.any? %>
      <div class="flex flex-wrap gap-2">
        <% @top_tags.each do |tag| %>
          <%= link_to tag_path(tag), class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-white rounded-full border border-gray-200 text-sm font-medium text-gray-700 hover:border-blue-300 hover:text-blue-700 transition" do %>
            <%= tag.name %>
            <span class="text-xs text-gray-400"><%= tag.agenda_items_count %></span>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-lg border border-gray-200 p-8 text-center">
        <p class="text-gray-500">No topics have been tagged yet.</p>
      </div>
    <% end %>
  </section>
</div>
