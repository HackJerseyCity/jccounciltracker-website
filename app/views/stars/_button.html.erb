<%= tag.span id: "star_button_#{starrable.class.name.underscore}_#{starrable.id}", class: "inline-flex" do %>
  <% if starred %>
    <%= button_to star_path(Current.user.stars.find_by(starrable: starrable)), method: :delete, class: "inline-flex items-center text-yellow-500 hover:text-yellow-600 cursor-pointer", data: { turbo_stream: true } do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
        <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
      </svg>
    <% end %>
  <% else %>
    <%= button_to stars_path, method: :post, params: { starrable_type: starrable.class.name, starrable_id: starrable.id }, class: "inline-flex items-center text-gray-400 hover:text-yellow-500 cursor-pointer", data: { turbo_stream: true } do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5Z" />
      </svg>
    <% end %>
  <% end %>
<% end %>
