<%# Hero Section %>
<section class="bg-white border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <div class="max-w-3xl">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 leading-tight">
        Know what your<br>
        <span class="text-blue-600">City Council</span> is doing.
      </h1>
      <p class="mt-6 text-lg text-gray-600 leading-relaxed max-w-2xl">
        CouncilTracker makes Jersey City council meetings searchable and transparent.
        See every ordinance, resolution, and vote &mdash; and how your representative voted.
      </p>
      <div class="mt-8">
        <%= link_to dashboard_path, class: "inline-flex items-center gap-2 px-6 py-3 bg-blue-600 text-white text-base font-semibold rounded-lg hover:bg-blue-700 transition-colors shadow-sm" do %>
          Start Exploring
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        <% end %>
      </div>
    </div>
  </div>
</section>


<%# About Section %>
<section class="bg-white border-t border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 ">
    <div class="max-w-2xl">
      <h2 class="text-2xl font-bold text-gray-900">Why CouncilTracker?</h2>
      <p class="mt-4 text-gray-600 leading-relaxed">
        City council meetings shape the rules, budgets, and priorities of Jersey City.
        But understanding what happens at these meetings shouldn't require reading
        hundreds of pages of PDFs.
      </p>
      <p class="mt-4 text-gray-600 leading-relaxed">
        CouncilTracker automatically processes meeting agendas and minutes to make
        council activity searchable, trackable, and understandable. Every vote, every
        ordinance, every resolution &mdash; organized and accessible.
      </p>
    </div>
  </div>
</section>