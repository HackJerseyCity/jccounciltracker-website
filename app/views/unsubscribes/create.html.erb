<div class="max-w-md mx-auto px-4 py-16">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 text-center">
    <h1 class="text-xl font-bold text-gray-900 mb-2">Unsubscribed</h1>
    <p class="text-sm text-gray-600 mb-6">
      <strong><%= @user.email_address %></strong> has been unsubscribed from newsletter emails.
    </p>
    <p class="text-xs text-gray-400">You can re-enable emails anytime from your <%= link_to "profile settings", edit_profile_path, class: "text-blue-600 hover:text-blue-800" %>.</p>
  </div>
</div>
