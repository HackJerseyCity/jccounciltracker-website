<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "CouncilTracker - Jersey City" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="CouncilTracker">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="Track Jersey City Council meetings, votes, and ordinances. See how your representatives vote on the issues that matter to you.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full flex flex-col bg-gray-50 text-gray-900 antialiased">
    <%# Compact top bar %>
    <header class="bg-white border-b border-gray-200">
      <div class="flex items-center justify-between h-14 px-4">
        <div class="flex items-center gap-2">
          <%= link_to root_path, class: "flex items-center gap-2 text-gray-900 hover:text-blue-700 transition-colors" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6M4.5 10.5v8.25A1.5 1.5 0 006 20.25h12a1.5 1.5 0 001.5-1.5V10.5" />
            </svg>
            <span class="text-base font-semibold tracking-tight">CouncilTracker</span>
          <% end %>
        </div>
        <div class="flex items-center gap-4 text-sm font-medium text-gray-600">
          <% if authenticated? %>
            <% if Current.session&.user&.admin? %>
              <%= link_to "Admin", admin_dashboard_path, class: "hover:text-blue-700 transition-colors" %>
            <% end %>
            <%= link_to "Profile", edit_profile_path, class: "hover:text-blue-700 transition-colors" %>
            <%= button_to "Sign out", session_path, method: :delete, class: "hover:text-blue-700 transition-colors cursor-pointer" %>
          <% else %>
            <%= link_to "Sign in", new_session_path, class: "hover:text-blue-700 transition-colors" %>
            <%= link_to "Sign up", new_signup_path, class: "hover:text-blue-700 transition-colors" %>
          <% end %>
        </div>
      </div>
    </header>

    <div class="flex flex-1 overflow-hidden" data-controller="sidebar">
      <%# Sidebar %>
      <aside data-sidebar-target="sidebar" class="w-16 bg-white border-r border-gray-200 flex flex-col transition-all duration-200 ease-in-out shrink-0">
        <div class="p-3">
          <button data-action="click->sidebar#toggle" class="w-10 h-10 flex items-center justify-center rounded-lg text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition-colors cursor-pointer" aria-label="Toggle sidebar">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </button>
        </div>

        <nav class="flex-1 px-3 space-y-1">
          <%= sidebar_link("Dashboard", dashboard_path, "dashboard") %>
          <%= sidebar_link("Meetings", meetings_path, "meetings") %>
          <%= sidebar_link("Council Members", council_members_path, "council_members") %>
          <%= sidebar_link("Topics", tags_path, "topics") %>
          <%= sidebar_link("Blog", blog_posts_path, "blog") %>
          <% if authenticated? %>
            <%= sidebar_link("Starred", stars_path, "starred") %>
          <% end %>
          <%= sidebar_link("Search", search_path, "search") %>
        </nav>
      </aside>

      <%# Main content %>
      <main class="flex-1 overflow-y-auto">
        <% if notice %>
          <div class="px-6 pt-4">
            <p class="py-2 px-3 bg-green-50 text-green-700 font-medium rounded-lg" id="notice"><%= notice %></p>
          </div>
        <% end %>
        <% if alert %>
          <div class="px-6 pt-4">
            <p class="py-2 px-3 bg-red-50 text-red-700 font-medium rounded-lg" id="alert"><%= alert %></p>
          </div>
        <% end %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
