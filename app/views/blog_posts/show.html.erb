<article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <header class="mb-10">
    <h1 class="text-4xl font-bold text-gray-900 leading-tight"><%= @blog_post.title %></h1>
    <div class="mt-4 text-sm text-gray-500">
      <span>By <%= @blog_post.author.name %></span>
      <span class="mx-1">&middot;</span>
      <time datetime="<%= @blog_post.published_at.iso8601 %>"><%= @blog_post.published_at.strftime("%B %-d, %Y") %></time>
    </div>
  </header>

  <div class="prose prose-lg max-w-none">
    <%= @blog_post.body %>
  </div>

  <div class="mt-12 pt-8 border-t border-gray-200">
    <%= link_to "&larr; More posts".html_safe, blog_posts_path, class: "text-sm font-medium text-blue-600 hover:text-blue-800" %>
  </div>
</article>
