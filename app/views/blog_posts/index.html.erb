<section class="p-6 sm:p-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Blog</h1>

  <% if @blog_posts.any? %>
    <div class="space-y-6">
      <% @blog_posts.each do |post| %>
        <article class="bg-white rounded-lg border border-gray-200 p-6">
          <h2 class="text-xl font-semibold text-gray-900">
            <%= link_to post.title, blog_post_path(post), class: "hover:text-blue-600 transition-colors" %>
          </h2>
          <div class="mt-2 text-sm text-gray-500">
            <span>By <%= post.author.name %></span>
            <span class="mx-1">&middot;</span>
            <time datetime="<%= post.published_at.iso8601 %>"><%= post.published_at.strftime("%B %-d, %Y") %></time>
          </div>
          <p class="mt-3 text-gray-600 line-clamp-3"><%= truncate(post.body.to_plain_text, length: 300) %></p>
          <div class="mt-4">
            <%= link_to "Read more", blog_post_path(post), class: "text-sm font-medium text-blue-600 hover:text-blue-800" %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white rounded-lg border border-gray-200 p-12 text-center">
      <p class="text-gray-500">No blog posts yet. Check back soon!</p>
    </div>
  <% end %>
</section>
