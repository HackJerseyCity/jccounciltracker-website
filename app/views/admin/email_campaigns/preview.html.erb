<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Preview: <%= @campaign.title %></title>
  </head>
  <body style="margin: 0; padding: 0; background-color: #f3f4f6; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
    <div style="text-align: center; padding: 12px; background-color: #fef3c7; border-bottom: 1px solid #fcd34d;">
      <span style="font-size: 13px; color: #92400e; font-weight: 600;">Email Preview</span>
      <span style="font-size: 12px; color: #b45309; margin-left: 8px;">This is how the email will appear to recipients.</span>
    </div>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color: #f3f4f6;">
      <tr>
        <td align="center" style="padding: 32px 16px;">
          <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width: 600px; width: 100%;">
            <tr>
              <td style="padding: 24px 32px; background-color: #1f2937; border-radius: 8px 8px 0 0;">
                <span style="color: #ffffff; font-size: 18px; font-weight: 600; letter-spacing: -0.025em;">CouncilTracker</span>
              </td>
            </tr>
            <tr>
              <td style="padding: 32px; background-color: #ffffff; color: #374151; font-size: 15px; line-height: 1.6;">
                <%= @campaign.body %>
              </td>
            </tr>
            <tr>
              <td style="padding: 20px 32px; background-color: #f9fafb; border-top: 1px solid #e5e7eb; border-radius: 0 0 8px 8px; text-align: center;">
                <p style="margin: 0; color: #9ca3af; font-size: 12px; line-height: 1.5;">
                  CouncilTracker is an independent civic transparency project.<br>
                  Not affiliated with the City of Jersey City.
                </p>
                <p style="margin: 12px 0 0; font-size: 12px;">
                  <span style="color: #6b7280; text-decoration: underline;">Unsubscribe from these emails</span>
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
