<%= form_with model: [:admin, campaign], class: "space-y-6" do |form| %>
  <% if campaign.errors.any? %>
    <div class="bg-red-50 rounded-lg p-4">
      <ul class="text-sm text-red-700 space-y-1">
        <% campaign.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, "Subject line", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :title, required: true, autofocus: true, placeholder: "e.g., March Council Recap", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500" %>
  </div>

  <div>
    <%= form.label :campaign_type, "Email category", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.select :campaign_type,
          EmailCampaign::CAMPAIGN_TYPES.map { |key, config| [config[:label], key] },
          {},
          class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500" %>
    <p class="mt-1 text-xs text-gray-500">Only users subscribed to this category will receive the email.</p>
  </div>

  <div>
    <%= form.label :body, "Email body", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.rich_text_area :body, class: "min-h-[20rem]" %>
  </div>

  <div class="flex items-center gap-3">
    <%= form.submit class: "px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors cursor-pointer" %>
    <% if campaign.persisted? %>
      <%= link_to "Cancel", admin_email_campaign_path(campaign), class: "px-4 py-2 text-sm font-medium text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" %>
    <% else %>
      <%= link_to "Cancel", admin_email_campaigns_path, class: "px-4 py-2 text-sm font-medium text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" %>
    <% end %>
  </div>
<% end %>
