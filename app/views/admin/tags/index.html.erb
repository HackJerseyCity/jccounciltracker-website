<div class="mb-6 sm:mb-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-xl sm:text-2xl font-bold text-gray-900">Tags</h1>
      <p class="mt-1 text-sm text-gray-500">Manage tags and auto-tag rules. Tags with 0 items can be safely removed.</p>
    </div>
    <% if TagRule.none? %>
      <%= button_to "Seed Default Rules", seed_rules_admin_tags_path, method: :post,
            class: "px-4 py-2 text-sm font-medium text-blue-700 bg-blue-50 rounded-lg hover:bg-blue-100 ring-1 ring-blue-600/10 transition-colors cursor-pointer",
            data: { turbo_confirm: "Create default auto-tag rules for common topics?" } %>
    <% end %>
  </div>
</div>

<%= form_with url: admin_tags_path, method: :get, local: true, class: "mb-6" do %>
  <div class="flex gap-2">
    <input type="text" name="q" value="<%= params[:q] %>" placeholder="Search tags..."
           class="flex-1 rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500"
           autocomplete="off" />
    <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors cursor-pointer">Search</button>
    <% if params[:q].present? %>
      <%= link_to "Clear", admin_tags_path, class: "px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors" %>
    <% end %>
  </div>
<% end %>

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 sm:px-6 text-left text-xs font-medium uppercase">
          <%= sortable_column("name", "Tag", path_helper: :admin_tags_path) %>
        </th>
        <th class="px-4 py-3 sm:px-6 text-left text-xs font-medium uppercase">
          <%= sortable_column("items", "Items", path_helper: :admin_tags_path, default_column: "items") %>
        </th>
        <th class="px-4 py-3 sm:px-6 text-left text-xs font-medium text-gray-500 uppercase">Auto-tag Rules</th>
        <th class="px-4 py-3 sm:px-6 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @tags.each do |tag| %>
        <%= render partial: "admin/tags/tag", locals: { tag: tag } %>
      <% end %>
    </tbody>
  </table>

  <% if @tags.empty? %>
    <div class="px-6 py-12 text-center text-sm text-gray-500">
      <% if params[:q].present? %>
        No tags matching "<%= params[:q] %>".
      <% else %>
        No tags yet.
      <% end %>
    </div>
  <% end %>
</div>
