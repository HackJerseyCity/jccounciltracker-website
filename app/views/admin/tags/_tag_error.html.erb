<tr id="<%= dom_id(tag) %>" class="bg-red-50/50" data-controller="inline-edit">
  <td class="px-4 py-3 sm:px-6 text-sm text-gray-900">
    <div data-inline-edit-target="display" class="hidden">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-indigo-100 text-indigo-800"><%= tag.name_was %></span>
    </div>
    <%= form_with model: tag, url: admin_tag_path(tag), method: :patch, data: { inline_edit_target: "form" } do |f| %>
      <div class="flex items-center gap-2">
        <%= f.text_field :name, class: "rounded-md border border-red-400 px-2 py-1 text-sm shadow-sm focus:border-red-500 focus:ring-red-500", data: { action: "keydown->inline-edit#keydown" } %>
        <button type="submit" class="text-green-600 hover:text-green-800 font-medium text-xs cursor-pointer">Save</button>
        <button type="button" class="text-gray-500 hover:text-gray-700 font-medium text-xs cursor-pointer" data-action="inline-edit#cancel">Cancel</button>
      </div>
      <p class="mt-1 text-xs text-red-600"><%= tag.errors.full_messages.to_sentence %></p>
    <% end %>
  </td>
  <td class="px-4 py-3 sm:px-6 text-sm"></td>
  <td class="px-4 py-3 sm:px-6 text-right text-sm"></td>
</tr>
