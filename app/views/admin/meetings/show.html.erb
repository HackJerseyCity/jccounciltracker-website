<%# Header %>
<div class="mb-6 sm:mb-8">
  <div class="flex items-center gap-2 text-sm text-gray-500 mb-3">
    <%= link_to "Meetings", admin_meetings_path, class: "hover:text-blue-600" %>
    <span>/</span>
    <span class="text-gray-900"><%= @meeting.date.strftime("%B %-d, %Y") %></span>
  </div>

  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
    <div>
      <h1 class="text-xl sm:text-2xl font-bold text-gray-900"><%= @meeting.display_name %></h1>
      <div class="mt-2 flex items-center gap-2 flex-wrap">
        <% if @agenda_version %>
          <% if @agenda_version.published? %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/10">Published</span>
          <% else %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-amber-50 text-amber-700 ring-1 ring-amber-600/10">Draft</span>
          <% end %>
        <% end %>
        <% if @meeting.minutes_imported? %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/10">Minutes imported</span>
        <% end %>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-2">
      <% if @agenda_version %>
        <% if @agenda_version.draft? %>
          <%= button_to "Publish", publish_admin_meeting_path(@meeting, version_id: @agenda_version.id), method: :post, class: "px-3.5 py-2 text-sm font-medium text-emerald-700 bg-emerald-50 rounded-lg hover:bg-emerald-100 ring-1 ring-emerald-600/10 transition-colors cursor-pointer" %>
        <% else %>
          <%= button_to "Unpublish", publish_admin_meeting_path(@meeting, version_id: @agenda_version.id), method: :post, class: "px-3.5 py-2 text-sm font-medium text-amber-700 bg-amber-50 rounded-lg hover:bg-amber-100 ring-1 ring-amber-600/10 transition-colors cursor-pointer", data: { turbo_confirm: "Are you sure you want to unpublish this version? It will no longer be visible to the public." } %>
        <% end %>
      <% end %>
      <% if @meeting.minutes_imported? %>
        <%= button_to "Delete Minutes", delete_minutes_admin_meeting_path(@meeting), method: :delete, class: "px-3.5 py-2 text-sm font-medium text-amber-700 bg-amber-50 rounded-lg hover:bg-amber-100 ring-1 ring-amber-600/10 transition-colors cursor-pointer", data: { turbo_confirm: "Are you sure you want to delete minutes data? This will remove all vote records for this meeting." } %>
      <% end %>
      <%= button_to "Delete Meeting", admin_meeting_path(@meeting), method: :delete, class: "px-3.5 py-2 text-sm font-medium text-red-600 bg-red-50 rounded-lg hover:bg-red-100 ring-1 ring-red-600/10 transition-colors cursor-pointer", data: { turbo_confirm: "Are you sure you want to delete this meeting?" } %>
    </div>
  </div>
</div>

<%# Version selector and import %>
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6 sm:mb-8">
  <% if @meeting.agenda_versions.size > 1 %>
    <%= form_with url: admin_meeting_path(@meeting), method: :get, local: true, class: "flex items-center gap-3" do %>
      <label for="version" class="text-sm font-medium text-gray-600">Version:</label>
      <select name="version" id="version" onchange="this.form.requestSubmit()" class="rounded-lg border-gray-300 shadow-sm text-sm focus:border-blue-500 focus:ring-blue-500">
        <% @meeting.agenda_versions.each do |v| %>
          <option value="<%= v.version_number %>" <%= "selected" if v == @agenda_version %>><%= v.display_label %> [<%= v.status.capitalize %>]</option>
        <% end %>
      </select>
    <% end %>
  <% else %>
    <div></div>
  <% end %>

  <div data-controller="upload-toggle">
    <div class="flex gap-2 mb-3">
      <button type="button" data-action="click->upload-toggle#showFile" data-upload-toggle-target="fileTab" class="px-2.5 py-1 text-xs font-medium rounded-md bg-blue-600 text-white transition-colors cursor-pointer">File</button>
      <button type="button" data-action="click->upload-toggle#showUrl" data-upload-toggle-target="urlTab" class="px-2.5 py-1 text-xs font-medium rounded-md bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors cursor-pointer">URL</button>
    </div>

    <div data-upload-toggle-target="filePanel">
      <%= form_with url: import_minutes_admin_meeting_path(@meeting), method: :post, multipart: true, class: "flex flex-col sm:flex-row sm:items-center gap-3" do %>
        <input type="file" name="minutes_file" accept=".json,.pdf" class="text-sm text-gray-500 file:mr-2 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-gray-100 file:text-gray-700 hover:file:bg-gray-200 file:cursor-pointer file:transition-colors max-w-full min-w-0" />
        <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors cursor-pointer">Import Minutes</button>
      <% end %>
    </div>

    <div data-upload-toggle-target="urlPanel" class="hidden">
      <%= form_with url: import_minutes_admin_meeting_path(@meeting), method: :post, class: "flex flex-col sm:flex-row sm:items-center gap-3" do %>
        <input type="url" name="minutes_url" placeholder="https://cityofjerseycity.civicweb.net/Portal/MeetingInformation.aspx?Id=..." class="rounded-lg border-gray-300 shadow-sm text-sm focus:border-blue-500 focus:ring-blue-500 max-w-full min-w-0 flex-1" />
        <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors cursor-pointer">Import from URL</button>
      <% end %>
    </div>
  </div>
</div>

<%# Stats %>
<div class="grid grid-cols-3 gap-3 sm:gap-4 mb-6 sm:mb-8">
  <div class="bg-white rounded-lg border border-gray-200 p-3 sm:p-5">
    <p class="text-xl sm:text-2xl font-bold text-gray-900"><%= @agenda_version&.agenda_pages || "N/A" %></p>
    <p class="text-xs sm:text-sm text-gray-500 mt-1">Agenda pages</p>
  </div>
  <div class="bg-white rounded-lg border border-gray-200 p-3 sm:p-5">
    <p class="text-xl sm:text-2xl font-bold text-gray-900"><%= @agenda_sections.size %></p>
    <p class="text-xs sm:text-sm text-gray-500 mt-1">Sections</p>
  </div>
  <div class="bg-white rounded-lg border border-gray-200 p-3 sm:p-5">
    <p class="text-xl sm:text-2xl font-bold text-gray-900"><%= @agenda_sections.sum { |s| s.agenda_items.size } %></p>
    <p class="text-xs sm:text-sm text-gray-500 mt-1">Agenda items</p>
  </div>
</div>

<%# Sections %>
<div class="space-y-6">
  <% @agenda_sections.each do |section| %>
    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden" data-controller="collapsible" data-collapsible-key-value="meeting-<%= @meeting.id %>-section-<%= section.id %>">
      <button type="button" data-action="click->collapsible#toggle" class="w-full px-4 sm:px-6 py-4 bg-gray-50 border-b border-gray-200 flex items-center justify-between cursor-pointer hover:bg-gray-100 transition-colors text-left">
        <div>
          <h2 class="font-semibold text-gray-900"><%= section.number %>. <%= section.title %></h2>
          <span class="text-xs text-gray-500"><%= section.section_type&.titleize %> &middot; <%= section.agenda_items.size %> items</span>
        </div>
        <svg data-collapsible-target="icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400 transition-transform duration-200 flex-shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
        </svg>
      </button>

      <div data-collapsible-target="content" class="overflow-x-hidden">
      <% if section.agenda_items.any? %>
        <%# Desktop table - hidden on mobile %>
        <table class="hidden lg:table min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-2 text-left text-xs font-medium text-gray-500 uppercase">#</th>
              <th class="px-6 py-2 text-left text-xs font-medium text-gray-500 uppercase">Title</th>
              <th class="px-6 py-2 text-left text-xs font-medium text-gray-500 uppercase">File #</th>
              <th class="px-6 py-2 text-left text-xs font-medium text-gray-500 uppercase">Pages</th>
              <th class="px-6 py-2 text-left text-xs font-medium text-gray-500 uppercase">PDF</th>
              <th class="px-6 py-2 text-left text-xs font-medium text-gray-500 uppercase">Result</th>
              <th class="px-6 py-2 text-left text-xs font-medium text-gray-500 uppercase">Tags</th>
              <th class="px-6 py-2"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% section.agenda_items.each do |item| %>
              <tr id="agenda_item_<%= item.id %>">
                <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-600"><%= item.item_number %></td>
                <%= render "admin/agenda_items/title", item: item %>
                <td class="px-6 py-3 whitespace-nowrap text-sm">
                  <% if item.file_number.present? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800"><%= item.file_number %></span>
                  <% end %>
                </td>
                <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500">
                  <% if item.page_start.present? %>
                    pp. <%= item.page_start %>-<%= item.page_end %>
                  <% end %>
                </td>
                <td class="px-6 py-3 whitespace-nowrap text-sm">
                  <% if item.url.present? %>
                    <%= link_to "View PDF", item.url, target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:text-blue-800" %>
                  <% end %>
                </td>
                <td class="px-6 py-3 whitespace-nowrap text-sm">
                  <% if item.result.present? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-50 text-blue-700"><%= item.result.titleize %></span>
                    <% if item.vote_tally.present? %>
                      <span class="text-gray-500 ml-1">(<%= item.vote_tally %>)</span>
                    <% end %>
                  <% end %>
                </td>
                <td class="px-6 py-3 text-sm">
                  <%= render "admin/agenda_item_tags/tags", agenda_item: item %>
                </td>
                <td class="px-6 py-3 whitespace-nowrap text-sm">
                  <%= button_to admin_agenda_item_path(item), method: :delete, class: "text-red-400 hover:text-red-600 transition-colors cursor-pointer", data: { turbo_confirm: "Delete this agenda item?" }, form: { class: "inline" } do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                    </svg>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>

        <%# Mobile cards - hidden on desktop %>
        <div class="lg:hidden divide-y divide-gray-200">
          <% section.agenda_items.each do |item| %>
            <div id="agenda_item_<%= item.id %>_mobile" class="p-4 space-y-3">
              <div class="flex items-start gap-2">
                <span class="text-xs font-medium text-gray-500 bg-gray-100 rounded px-1.5 py-0.5 flex-shrink-0"><%= item.item_number %></span>
                <%= render "admin/agenda_items/title_mobile", item: item %>
                <%= button_to admin_agenda_item_path(item), method: :delete, class: "text-red-400 hover:text-red-600 transition-colors cursor-pointer flex-shrink-0 ml-auto", data: { turbo_confirm: "Delete this agenda item?" }, form: { class: "inline" } do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                  </svg>
                <% end %>
              </div>

              <div class="flex flex-wrap items-center gap-2 text-xs">
                <% if item.file_number.present? %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded font-medium bg-gray-100 text-gray-800"><%= item.file_number %></span>
                <% end %>
                <% if item.page_start.present? %>
                  <span class="text-gray-500">pp. <%= item.page_start %>-<%= item.page_end %></span>
                <% end %>
                <% if item.url.present? %>
                  <%= link_to "PDF", item.url, target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:text-blue-800 font-medium" %>
                <% end %>
                <% if item.result.present? %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded font-medium bg-blue-50 text-blue-700"><%= item.result.titleize %></span>
                  <% if item.vote_tally.present? %>
                    <span class="text-gray-500">(<%= item.vote_tally %>)</span>
                  <% end %>
                <% end %>
              </div>

              <div>
                <%= render "admin/agenda_item_tags/tags", agenda_item: item, id_suffix: "_mobile" %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
      </div>
    </div>
  <% end %>
</div>
