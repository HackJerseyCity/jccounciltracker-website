<div class="mb-6">
  <nav class="text-sm text-gray-500 mb-4">
    <%= link_to "Blog Posts", admin_blog_posts_path, class: "hover:text-blue-600" %> <span class="mx-1">/</span>
    <span class="text-gray-900"><%= @blog_post.title %></span>
  </nav>

  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @blog_post.title %></h1>
      <div class="mt-2 flex items-center gap-3 text-sm text-gray-500">
        <span>By <%= @blog_post.author.name %></span>
        <span>&middot;</span>
        <span>Slug: <code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs"><%= @blog_post.slug %></code></span>
        <span>&middot;</span>
        <% if @blog_post.published? %>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Published <%= @blog_post.published_at.strftime("%b %-d, %Y at %-I:%M %p") %></span>
        <% else %>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800">Draft</span>
        <% end %>
      </div>
    </div>
    <div class="flex items-center gap-3">
      <%= button_to @blog_post.published? ? "Unpublish" : "Publish", publish_admin_blog_post_path(@blog_post), method: :post, class: "px-4 py-2 text-sm font-medium rounded-lg border #{@blog_post.published? ? 'border-yellow-300 text-yellow-700 hover:bg-yellow-50' : 'border-green-300 text-green-700 hover:bg-green-50'} transition-colors cursor-pointer" %>
      <%= link_to "Edit", edit_admin_blog_post_path(@blog_post), class: "px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors" %>
      <%= button_to "Delete", admin_blog_post_path(@blog_post), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this post?" }, class: "px-4 py-2 text-sm font-medium text-red-600 border border-red-300 rounded-lg hover:bg-red-50 transition-colors cursor-pointer" %>
    </div>
  </div>
</div>

<div class="bg-white rounded-lg border border-gray-200 p-8">
  <div class="prose max-w-none">
    <%= @blog_post.body %>
  </div>
</div>

<% if @blog_post.published? %>
  <div class="mt-4 text-sm text-gray-500">
    <%= link_to "View on site", blog_post_path(@blog_post), class: "text-blue-600 hover:text-blue-800", target: "_blank" %>
  </div>
<% end %>
