<%= form_with model: [:admin, blog_post], class: "space-y-6" do |form| %>
  <% if blog_post.errors.any? %>
    <div class="bg-red-50 rounded-lg p-4">
      <ul class="text-sm text-red-700 space-y-1">
        <% blog_post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :title, required: true, autofocus: true, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500" %>
  </div>

  <div>
    <%= form.label :slug, "Slug (leave blank to auto-generate)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :slug, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 font-mono text-sm", placeholder: "auto-generated-from-title" %>
  </div>

  <div>
    <%= form.label :body, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.rich_text_area :body, class: "min-h-[20rem]" %>
  </div>

  <div class="flex items-center gap-3">
    <%= form.submit class: "px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors cursor-pointer" %>
    <% if blog_post.persisted? %>
      <%= link_to "Cancel", admin_blog_post_path(blog_post), class: "px-4 py-2 text-sm font-medium text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" %>
    <% else %>
      <%= link_to "Cancel", admin_blog_posts_path, class: "px-4 py-2 text-sm font-medium text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" %>
    <% end %>
  </div>
<% end %>
